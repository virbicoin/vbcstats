{
  "name": "vbc-netstats",
  "version": "0.3.0",
  "private": true,
  "description": "A web application for visualizing VBC blockchain statistics.",
  "author": "Aoi Emerauda",
  "license": "MIT",
  "keywords": [
    "vbc",
    "blockchain",
    "visualization",
    "statistics",
    "web3",
    "nextjs",
    "react",
    "typescript",
    "nodejs",
    "express",
    "leaflet",
    "geoip",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/virbicoin/vbcstats.git"
  },
  "bugs": {
    "url": "https://github.com/virbicoin/vbcstats/issues"
  },
  "homepage": "https://github.com/virbicoin/vbcstats#readme",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env server.ts",
    "prebuild": "npm run check",
    "build": "next build && ./scripts/copy-geoip-data.sh",
    "start": "NODE_ENV=production tsx --env-file-if-exists=.env server.ts",
    "check": "eslint app lib && tsc --noEmit && npm run format:check",
    "lint": "eslint app lib",
    "lint:fix": "eslint app lib --fix",
    "format": "prettier --write \"{app,lib,types}/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"{app,lib,types}/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.2",
    "leaflet": "^1.9.4",
    "lodash": "^4.18.1",
    "next": "^16.2.6",
    "primus": "^8.0.9",
    "primus-client": "^7.3.4",
    "primus-emit": "^1.0.0",
    "primus-spark-latency": "^0.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "tsx": "^4.22.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/leaflet": "^1.9.21",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "overrides": {
    "typescript-eslint": "^8.59.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0"
  }
}
