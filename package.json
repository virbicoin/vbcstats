{
  "name": "vbc-netstats",
  "version": "0.2.0",
  "private": true,
  "description": "A web application for visualizing VBC blockchain statistics.",
  "author": "Aoi Emerauda",
  "license": "MIT",
  "keywords": [
    "vbc",
    "blockchain",
    "visualization",
    "statistics",
    "web3",
    "nextjs",
    "react",
    "typescript",
    "nodejs",
    "express",
    "leaflet",
    "geoip",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/virbicoin/vbcstats.git"
  },
  "bugs": {
    "url": "https://github.com/virbicoin/vbcstats/issues"
  },
  "homepage": "https://github.com/virbicoin/vbcstats#readme",
  "scripts": {
    "server-dev": "bash -c 'set -a; [ -f .env ] && source .env; set +a; WS_SECRET=\"$WS_SECRET\" PORT_SERVER=\"$PORT_SERVER\" node ./server-simple.js'",
    "next-dev": "bash -c 'set -a; [ -f .env ] && source .env; set +a; next dev -p \"$PORT\"'",
    "dev": "concurrently \"npm:server-dev\" \"npm:next-dev\"",
    "build": "next build",
    "next-start": "bash -c 'set -a; [ -f .env ] && source .env; set +a; next start -p \"$PORT\"'",
    "start": "concurrently \"npm:server-dev\" \"npm:next-start\"",
    "check": "next lint && tsc --noEmit",
    "lint": "next lint",
    "lint:fix": "next lint --fix"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@types/recharts": "^1.8.29",
    "@types/ws": "^8.18.1",
    "body-parser": "^2.2.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "d3": "^3.5.17",
    "debug": "^4.4.1",
    "express": "^5.1.0",
    "framer-motion": "^12.23.3",
    "geoip-lite": "^1.4.10",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "next": "15.3.5",
    "next-themes": "^0.4.6",
    "primus": "^8.0.9",
    "primus-client": "^7.3.4",
    "primus-emit": "^1.0.0",
    "primus-msgpack": "^1.0.2",
    "primus-spark-latency": "^0.1.1",
    "pug": "^3.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.1.0",
    "web3": "^4.16.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.3",
    "@types/geoip-lite": "^1.4.4",
    "@types/leaflet": "^1.9.20",
    "@types/lodash": "^4.17.20",
    "@types/node": "24.0.13",
    "@types/primus": "^7.3.9",
    "@types/pug": "^2.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.1",
    "eslint-config-next": "15.3.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
