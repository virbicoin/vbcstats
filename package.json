{
  "name": "vbc-netstats",
  "version": "0.2.2",
  "private": true,
  "description": "A web application for visualizing VBC blockchain statistics.",
  "author": "Aoi Emerauda",
  "license": "MIT",
  "keywords": [
    "vbc",
    "blockchain",
    "visualization",
    "statistics",
    "web3",
    "nextjs",
    "react",
    "typescript",
    "nodejs",
    "express",
    "leaflet",
    "geoip",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/virbicoin/vbcstats.git"
  },
  "bugs": {
    "url": "https://github.com/virbicoin/vbcstats/issues"
  },
  "homepage": "https://github.com/virbicoin/vbcstats#readme",
  "scripts": {
    "server-dev": "bash -c 'set -a; [ -f .env ] && source .env; set +a; WS_SECRET=\"$WS_SECRET\" PORT_SERVER=\"$PORT_SERVER\" node ./server-simple.js'",
    "next-dev": "bash -c 'set -a; [ -f .env ] && source .env; set +a; next dev -p \"$PORT\"'",
    "dev": "concurrently \"npm:server-dev\" \"npm:next-dev\"",
    "prebuild": "npm run check",
    "build": "next build && ./scripts/copy-geoip-data.sh",
    "next-start": "bash -c 'set -a; [ -f .env ] && source .env; set +a; next start -p \"$PORT\"'",
    "start": "concurrently \"npm:server-dev\" \"npm:next-start\"",
    "check": "next lint && tsc --noEmit",
    "lint": "next lint",
    "lint:fix": "next lint --fix"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "body-parser": "^2.2.1",
    "chalk": "^5.6.2",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "debug": "^4.4.3",
    "express": "^5.2.0",
    "geoip-lite": "^1.4.10",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "next": "^16.0.10",
    "primus": "^8.0.9",
    "primus-client": "^7.3.4",
    "primus-emit": "^1.0.0",
    "primus-spark-latency": "^0.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.6.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/leaflet": "^1.9.21",
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.0.3",
    "@types/primus": "^7.3.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
