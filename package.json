{
  "name": "vbc-stats",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "A web application for visualizing VBC blockchain statistics.",
  "author": "Aoi Emerauda",
  "license": "MIT",
  "keywords": [
    "vbc",
    "blockchain",
    "visualization",
    "statistics",
    "web3",
    "nextjs",
    "react",
    "typescript",
    "nodejs",
    "express",
    "leaflet",
    "geoip",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/virbicoin/vbc-stats.git"
  },
  "bugs": {
    "url": "https://github.com/virbicoin/vbc-stats/issues"
  },
  "homepage": "https://github.com/virbicoin/vbc-stats#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "tsx --env-file-if-exists=.env server.ts",
    "prebuild": "npm run check",
    "build": "next build && ./scripts/copy-geoip-data.sh",
    "start": "NODE_ENV=production tsx --env-file-if-exists=.env server.ts",
    "check": "npm run lint && npm run format:check && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "updatedb": "node --env-file-if-exists=.env ./node_modules/geoip-lite/scripts/updatedb.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/postcss": "^4.3.0",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lodash": "^4.18.1",
    "next": "^16.2.7",
    "primus": "^8.0.9",
    "primus-client": "^7.3.4",
    "primus-emit": "^1.0.0",
    "primus-spark-latency": "^0.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.12",
    "@next/eslint-plugin-next": "^16.2.7",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10"
  }
}
